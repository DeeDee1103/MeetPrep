{
  "name": "meetprep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "email": "email dev --dir src/emails",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "screenshots": "node scripts/screenshots.js",
    "screenshots:install": "npx playwright install chromium --with-deps"
  },
  "dependencies": {
    "next": "14.2.5",
    "inngest": "^3.24.0",
    "@supabase/supabase-js": "^2.44.4",
    "@supabase/ssr": "^0.4.0",
    "stripe": "^16.0.0",
    "resend": "^3.4.0",
    "@anthropic-ai/sdk": "^0.26.0",
    "@react-email/components": "^0.0.22",
    "react-email": "^3.0.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.4.0",
    "date-fns": "^3.6.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "typescript": "^5",
    "tailwindcss": "^3.4.1",
    "postcss": "^8",
    "autoprefixer": "^10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "vitest": "^1.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.4.6",
    "jsdom": "^24.1.1",
    "@vitest/coverage-v8": "^1.6.0",
    "playwright": "^1.46.0"
  }
}
